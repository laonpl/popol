{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "프론트엔드 시작",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "line": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:.*localhost"
        }
      },
      "presentation": {
        "group": "devServers",
        "reveal": "always",
        "panel": "dedicated",
        "label": "프론트엔드"
      }
    }
  ]
}

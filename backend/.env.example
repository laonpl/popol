# ─────────────────────────────────────────────
# Backend 환경변수 (Render 대시보드 → Environment에 입력)
# ─────────────────────────────────────────────

# 서버 포트 (Render는 자동 주입, 기본 10000)
PORT=5000

# 프론트엔드 URL (Vercel 배포 후 설정) - CORS 허용 도메인
FRONTEND_URL=https://your-app.vercel.app

# Gemini API 키
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK - serviceAccountKey.json 파일 내용을 한 줄 JSON으로 붙여넣기
# 예: {"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n..."}
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Notion 통합 토큰 (내보내기 기능 사용 시)
NOTION_INTEGRATION_TOKEN=secret_xxx
